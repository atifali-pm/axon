# ============================================================
# DOMAIN & APP
# ============================================================
DOMAIN=localhost
NODE_ENV=development
LOG_LEVEL=debug
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ============================================================
# POSTGRES
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=axon
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/axon

# ============================================================
# REDIS
# ============================================================
REDIS_PASSWORD=
REDIS_URL=redis://default:${REDIS_PASSWORD}@localhost:6379

# ============================================================
# AUTH (Better Auth)
# ============================================================
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=${APP_URL}

# OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# LLM PROVIDERS
# ============================================================
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================
# OBSERVABILITY
# ============================================================
LANGFUSE_SECRET=
LANGFUSE_SALT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

GRAFANA_USER=admin
GRAFANA_PASSWORD=

# ============================================================
# STORAGE
# ============================================================
MINIO_USER=minioadmin
MINIO_PASSWORD=
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=uploads
S3_REGION=us-east-1

# ============================================================
# PAYMENTS
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ============================================================
# EMAIL
# ============================================================
RESEND_API_KEY=
EMAIL_FROM=hello@${DOMAIN}

# ============================================================
# N8N
# ============================================================
N8N_ENCRYPTION_KEY=

# ============================================================
# AGENT SERVICE
# ============================================================
AGENT_SERVICE_URL=http://localhost:8000
AGENT_API_KEY=

# ============================================================
# CLOUDFLARE
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================
# PORTS (override if needed)
# ============================================================
WEB_PORT=3000
API_PORT=4000
AGENTS_PORT=8000

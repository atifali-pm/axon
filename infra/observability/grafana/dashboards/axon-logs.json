{
  "title": "Axon Logs",
  "uid": "axon-logs",
  "tags": ["axon", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "All container logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{project=\"axon-dev\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
